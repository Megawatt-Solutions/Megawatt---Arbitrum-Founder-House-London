# ── Spreadcast environment ───────────────────────────────────────
# Everything is optional for the local prototype: without any of these the
# app runs in demo mode (simulated prices, simulated on-chain submits).

# ENTSO-E Transparency Platform security token (free registration).
# When set, settlement uses real A44 day-ahead prices for SI (10YSI-ELES-----O).
ENTSOE_TOKEN=

# XRPL network. Mainnet default; use wss://s.altnet.rippletest.net:51233 for testnet.
XRPL_WSS=wss://xrplcluster.com

# Platform anchor account (receives 1-drop commit signatures, sends weekly
# Merkle anchors). Seed stays with the CTO; never commit it.
XRPL_ANCHOR_ADDRESS=
XRPL_ANCHOR_SEED=

# Xaman (XUMM) app credentials for wallet connect + commit signing.
XUMM_API_KEY=
XUMM_API_SECRET=

# Session cookie HMAC secret (any long random string) + admin key for
# manually triggering jobs (settle/recalibrate) in the prototype.
SESSION_SECRET=
ADMIN_KEY=
