# /etc/spreadcast/worker.env — root:spreadcast 640, NEVER in git.
DATABASE_URL=postgres://spreadcast:CHANGE_ME@localhost:5432/spreadcast

# XRPL mainnet
XRPL_WSS=wss://xrplcluster.com
# Anchor account (receives 1-drop commits; sends weekly Merkle anchors).
# Listener + backfill activate when the address is set; real anchor
# submission additionally needs the seed (place it directly on the server).
XRPL_ANCHOR_ADDRESS=
XRPL_ANCHOR_SEED=

# ENTSO-E Transparency Platform token — real SI day-ahead prices when set,
# deterministic simulator fallback otherwise (rows are tagged by source).
ENTSOE_TOKEN=
# Alternative to the seed: Xaman secret numbers (8 groups of 6 digits,
# space-separated in one line).
XRPL_ANCHOR_SECRET_NUMBERS=
