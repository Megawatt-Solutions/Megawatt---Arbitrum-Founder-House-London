# ── Megawatt web app environment ─────────────────────────────────
# Copy to .env.local — everything is optional; features light up as
# credentials are added.

# Xaman (XUMM) sign-in — free app credentials from https://apps.xumm.dev
# With these set, Connect Wallet shows the Xaman QR / deep-link sign-in
# (proves address ownership). Without them the watch-only fallback is used.
XUMM_API_KEY=
XUMM_API_SECRET=

# XRPL mainnet WebSocket override (defaults to wss://xrplcluster.com with
# s1/s2.ripple.com fallbacks).
XRPL_WSS=
