# ─────────────────────────────────────────────────────────────
# Megawatt — environment template. Copy to `.env` and fill in.
# NEVER commit the real `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# XRPL EVM Sidechain — Testnet
RPC_URL=https://rpc.testnet.xrplevm.org
CHAIN_ID=1449000
EXPLORER_URL=https://explorer.testnet.xrplevm.org

# Deployer — TESTNET BURNER ONLY. Never reuse for mainnet.
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
PRIVATE_KEY=

# ─── Frontend (web/.env.local) — public, filled after deploy ──
NEXT_PUBLIC_CHAIN_ID=1449000
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.xrplevm.org
NEXT_PUBLIC_EXPLORER_URL=https://explorer.testnet.xrplevm.org
